<Window x:Class="CSaN_Lab2.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент — TCP Чат" Height="620" Width="820"
        WindowStartupLocation="CenterScreen" Background="#F8F9FA"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="IP сервера:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtIP" Width="160" Text="127.0.0.1" Margin="0,0,24,0"/>

                <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtPort" Width="80" Text="5000"/>

                <Button x:Name="btnConnect" Content="Подключиться" Width="140" Margin="24,0,0,0"
                        Background="#10B981" Foreground="White" Click="Connect_Click"/>
                <Button x:Name="btnDisconnect" Content="Отключиться" Width="120" Margin="12,0,0,0"
                        Background="#EF4444" Foreground="White" Visibility="Collapsed" Click="Disconnect_Click"/>
            </StackPanel>
        </Border>

        <TextBlock x:Name="txtStatus" Grid.Row="1" Text="Не подключено" 
                   HorizontalAlignment="Center" Margin="0,8" Foreground="Gray"/>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12">
            <TextBox x:Name="txtChat" IsReadOnly="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                     BorderThickness="0" Background="Transparent"/>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtMessage" Height="38" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="Отправить" Width="110" Margin="12,0,0,0"
                    Background="#3B82F6" Foreground="White" Click="SendMessage_Click"/>
            <Button Grid.Column="2" Content="Файл..." Width="100" Margin="12,0,0,0"
                    Background="#10B981" Foreground="White" Click="SendFile_Click"/>
        </Grid>
    </Grid>
</Window>