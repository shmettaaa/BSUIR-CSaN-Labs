<Window x:Class="CSaN_Lab2.ServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сервер — TCP Чат" Height="650" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                <TextBox x:Name="txtIP" Width="140" Text="0.0.0.0" Margin="0,0,24,0"/>

                <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                <TextBox x:Name="txtPort" Width="80" Text="5000" Margin="0,0,24,0"/>

                <Button x:Name="btnStart" Content="Запустить" Width="120" Margin="0,0,12,0"
                        Background="#3B82F6" Foreground="White" Click="Start_Click"/>
                <Button x:Name="btnStop" Content="Остановить" Width="120" Margin="12,0,0,0"
                        Background="#EF4444" Foreground="White" Visibility="Collapsed" Click="Stop_Click"/>
            </StackPanel>
        </Border>

        <TextBlock x:Name="txtStatus" Grid.Row="1" Text="Сервер не запущен" 
                   HorizontalAlignment="Center" Margin="0,12" Foreground="Gray" FontSize="14"/>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12" Margin="0,12">
            <TextBox x:Name="txtChat" IsReadOnly="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                     BorderThickness="0" Background="Transparent" FontSize="13"/>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="IP получателя:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtTargetIP" Width="180" Margin="0,0,12,0"/>
            </StackPanel>

            <TextBox Grid.Row="1" x:Name="txtMessage" Height="60" AcceptsReturn="True" 
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Файл..." Width="100" Margin="0,0,12,0" Click="SendFile_Click"/>
                <Button Content="Отправить" Width="120" Click="SendMessage_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>